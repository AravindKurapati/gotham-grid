GH_TOKEN=ghp_...               # optional: raises GitHub live-scan rate limits (use GH_TOKEN — GITHUB_ prefix is reserved by GitHub Actions)
TAVILY_API_KEY=tvly-...        # optional: enables non-GitHub source (blogs, civic sites). Free tier covers normal use.
GROQ_API_KEY=gsk_...           # optional: required when TAVILY_API_KEY is set (parses web results)
SCAN_CODE=                     # optional: gate live scan behind invite code
STATIC_ONLY=false              # set true to disable live scan entirely
